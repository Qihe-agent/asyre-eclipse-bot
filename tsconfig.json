{
    "compilerOptions": {
        "jsx": "react",
        "target": "ES2022",
        "lib": ["ES2022"],
        "module": "CommonJS",
        "outDir": "dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true
    },
    "include": [
        "src",
        "global.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "temp/"
    ]
}
